# ============================================================
# Stripe — echte Zahlung im Marketplace
# ============================================================
# Holen: https://dashboard.stripe.com/apikeys
# Für Tests: sk_test_... / pk_test_...  (verwendet Test-Karten wie 4242 4242 4242 4242)
# Für Live:  sk_live_... / pk_live_...  (bucht echtes Geld)
STRIPE_SECRET_KEY=

# Webhook-Secret — aus dem Stripe Dashboard unter:
# Developers > Webhooks > [dein Endpoint] > Signing secret
# Optional: Ohne Webhook funktioniert der Kauf trotzdem, aber die
# Freischaltung läuft nur über den Redirect-Fallback (/api/market/confirm).
# Für Produktion empfohlen, damit verlorene Redirects nicht zu nicht-
# freigeschalteten Käufen führen.
STRIPE_WEBHOOK_SECRET=

# Öffentliche URL deines Servers (für Stripe success_url/cancel_url).
# Muss von außen erreichbar sein. Bei lokalem Test reicht http://localhost:3000.
# Bei Produktion: https://deine-domain.de
PUBLIC_URL=http://localhost:3000

# Port (optional, default 3000)
# PORT=3000
